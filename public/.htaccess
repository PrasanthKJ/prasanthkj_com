# Hostinger Shared Hosting Apache Configuration for prasanthkj.com
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Preserve WordPress Blog at public_html/blog
  RewriteRule ^blog(/.*)?$ - [L]

  # 2. Serve static assets & files directly if they exist
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 3. Fallback all main site routes to React index.html
  RewriteRule ^ index.html [L]
</IfModule>

# Enable Gzip Compression for 90+ PageSpeed
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json image/svg+xml
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>
